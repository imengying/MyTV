{
  "name": "mytv",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "dev": "pnpm sync:version && pnpm gen:manifest && next dev --webpack -H 0.0.0.0",
    "build": "pnpm sync:version && pnpm gen:manifest && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && pnpm format",
    "lint:strict": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit --incremental false",
    "test:watch": "jest --watch",
    "test": "jest",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "sync:version": "node scripts/sync-version.js",
    "gen:manifest": "node scripts/generate-manifest.js",
    "postbuild": "echo 'Build completed - sitemap generation disabled'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/crypto-js": "^4.2.2",
    "@vidstack/react": "^1.12.13",
    "artplayer": "^5.4.0",
    "bs58": "^6.0.0",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "framer-motion": "^12.38.0",
    "he": "^1.2.0",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.438.0",
    "media-icons": "^1.1.5",
    "next": "^16.2.1",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "swiper": "^11.2.10",
    "tailwind-merge": "^2.6.1",
    "vidstack": "^0.6.15",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/he": "^1.2.3",
    "@types/node": "24.12.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^27.5.1",
    "next-router-mock": "^1.0.5",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "webpack-obfuscator": "^3.6.0"
  },
  "packageManager": "pnpm@10.33.0"
}
